{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Crovver",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "colors": {
    "primary": "#3B7573",
    "light": "#5A9997",
    "dark": "#2A5755"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.crovver.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://app.crovver.com"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "icon": "book-open",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "icon": "blocks",
            "pages": [
              "concepts/organizations",
              "concepts/tenants",
              "concepts/plans",
              "concepts/subscriptions",
              "concepts/entitlements"
            ]
          },
          {
            "group": "Authentication",
            "icon": "shield",
            "pages": [
              "authentication/overview",
              "authentication/public-keys",
              "authentication/api-keys"
            ]
          },
          {
            "group": "SDKs",
            "icon": "code",
            "pages": [
              {
                "group": "React SDK",
                "icon": "atom",
                "pages": [
                  "react-sdk/installation",
                  "react-sdk/crovver-provider",
                  {
                    "group": "Hooks",
                    "pages": [
                      "react-sdk/hooks/use-subscription",
                      "react-sdk/hooks/use-feature-access",
                      "react-sdk/hooks/use-billing-redirect"
                    ]
                  },
                  {
                    "group": "Components",
                    "pages": [
                      "react-sdk/components/paywall",
                      "react-sdk/components/feature-guard",
                      "react-sdk/components/subscription-badge"
                    ]
                  }
                ]
              },
              {
                "group": "PHP SDK",
                "icon": "terminal",
                "pages": ["php-sdk/installation"]
              },
              {
                "group": "Node.js SDK",
                "icon": "zap",
                "pages": ["node-sdk/installation"]
              }
            ]
          },
          {
            "group": "Guides",
            "icon": "map",
            "pages": [
              "guides/checkout-flow",
              "guides/seat-based-billing",
              "guides/webhooks",
              "guides/test-mode"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "icon": "file-code",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Subscriptions",
            "icon": "credit-card",
            "pages": [
              "api-reference/subscriptions/status",
              "api-reference/subscriptions/cancel"
            ]
          },
          {
            "group": "Checkout",
            "icon": "shopping-cart",
            "pages": [
              "api-reference/checkout/create-session",
              "api-reference/checkout/checkout-token",
              "api-reference/checkout/portal-token"
            ]
          },
          {
            "group": "Features & Usage",
            "icon": "bar-chart-2",
            "pages": [
              "api-reference/features/can-access",
              "api-reference/usage/record",
              "api-reference/usage/check-limit"
            ]
          },
          {
            "group": "Plans",
            "icon": "list",
            "pages": ["api-reference/plans/list"]
          },
          {
            "group": "Tenants",
            "icon": "users",
            "pages": [
              "api-reference/tenants/create",
              "api-reference/tenants/list"
            ]
          }
        ]
      }
